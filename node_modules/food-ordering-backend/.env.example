# ===========================================
# Backend Environment Variables - .env.example
# Copy this file to .env and fill in your values
# ===========================================

# Server
PORT=5000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here_minimum_32_characters
JWT_EXPIRES_IN=24h

# Client URL for CORS (use * for development, your domain for production)
CLIENT_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: Full Railway connection URL (overrides individual settings below)
DATABASE_URL=mysql://root:your_mysql_password@your-host:3306/railway

# Option B: Railway individual environment variables (set automatically by Railway)
MYSQLHOST=your-host
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=your_mysql_password
MYSQLDATABASE=railway

# Option C: Standard individual environment variables (for local development)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_local_mysql_password
DB_NAME=cravingdash

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Get your test keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_test_key_secret
